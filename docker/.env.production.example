# Copy to docker/.env.production and replace every placeholder.
# Do not commit docker/.env.production.

DEER_FLOW_ENV=production
ENVIRONMENT=production

# Host-side persistent runtime directory. This must survive container rebuilds.
DEER_FLOW_HOME=/data/deer-flow

# Container-side config paths consumed by the Gateway.
DEER_FLOW_CONFIG_PATH=/app/backend/config.yaml
DEER_FLOW_EXTENSIONS_CONFIG_PATH=/app/backend/extensions_config.json

# Host-side files mounted by docker/docker-compose.production.yaml.
DEER_FLOW_CONFIG_HOST_PATH=/data/deer-flow/config.yaml
DEER_FLOW_EXTENSIONS_CONFIG_HOST_PATH=/data/deer-flow/extensions_config.json

# Repository and sandbox wiring.
DEER_FLOW_REPO_ROOT=/opt/deer-flow
DEER_FLOW_DOCKER_SOCKET=/var/run/docker.sock

# Provider secrets.
DEEPSEEK_API_KEY=replace_me

# Auth and internal service secrets.
AUTH_JWT_SECRET=replace_me
BETTER_AUTH_SECRET=replace_me
DEER_FLOW_INTERNAL_AUTH_TOKEN=replace_me

# Gateway hardening.
GATEWAY_ENABLE_DOCS=false
GATEWAY_WORKERS=1
GATEWAY_CORS_ORIGINS=https://app.example.com
AUTH_TRUSTED_PROXIES=replace_me

# Optional search/fetch provider keys. Leave unset unless configured.
TAVILY_API_KEY=replace_me
JINA_API_KEY=replace_me
SERPER_API_KEY=replace_me

# Public port exposed by docker/docker-compose.yaml nginx.
PORT=2026

